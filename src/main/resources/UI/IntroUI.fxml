<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="450.0" prefWidth="1000.0" styleClass="windowBackground" stylesheets="@style.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.IntroController">
   <children>
      <Label layoutX="405.0" layoutY="14.0" style="-fx-font-weight: bold;" text="2FastHands">
         <font>
            <Font size="40.0" />
         </font>
      </Label>
      <Label layoutX="5.0" layoutY="78.0" prefHeight="268.0" prefWidth="992.0" text="- The game consist of 2 parts, firstly you need type all of the displayed words correctly. &#10;- If you mistype a word, the words refill and the timer continues until you either succeed&#10;  or fail.&#10;- If you correctly type everything out, you will then have a secret word on your screen &#10;   that is shuffled. Your job is to figure out what the word is and type it.&#10;- If you incorrectly type out the word a red &quot;X&quot; will come out. If you succeed the cycle &#10;   repeats itself but with less time.&#10;&#10;&#10;&#10;&#10;&#10;">
         <font>
            <Font size="25.0" />
         </font>
      </Label>
      <Button fx:id="startBtn" layoutX="423.0" layoutY="362.0" mnemonicParsing="false" prefHeight="58.0" prefWidth="156.0" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-font-size: 30px" text="START" textAlignment="CENTER" textFill="#b90f0f" />
      <Label layoutX="572.0" layoutY="381.0" style="-fx-font-weight: bold;" text=" (The game starts as soon as you press start)">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
   </children>
